generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  MANAGER
  STAFF
}

enum MembershipAction {
  ADD
  REMOVE
  UPDATE_ROLE
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Organization {
  id          String   @id @default(cuid())
  name        String
  stackTeamId String   @unique // Stack Auth Team ID

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members            Member[]
  products           Product[]
  membershipRequests MembershipRequest[]
  invitations        Invitation[]
}

model Member {
  id             String       @id @default(cuid())
  userId         String       // Stack Auth User ID
  organizationId String
  role           Role

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model Invitation {
  id             String       @id @default(cuid())
  email          String
  organizationId String
  stackInviteId  String?      // Stack Auth invitation ID
  status         String       @default("PENDING") // PENDING | ACCEPTED | REVOKED

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([email, organizationId])
  @@index([organizationId])
}

model MembershipRequest {
  id             String           @id @default(cuid())
  organizationId String
  requesterId    String           // Stack Auth User ID of requester
  targetUserId   String           // Stack Auth User ID of target
  action         MembershipAction
  newRole        Role?            // Only for UPDATE_ROLE
  status         ApprovalStatus   @default(PENDING)
  approverId     String?          // Stack Auth User ID of approver/rejecter
  resolvedAt     DateTime?

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Prevent duplicate PENDING requests for same target+action
  @@unique([organizationId, targetUserId, action, status])
  @@index([organizationId, status])
}

model Product {
  id             String       @id @default(cuid())
  organizationId String       // replaces userId
  name           String
  sku            String?
  price          Decimal      @db.Decimal(12, 2)
  quantity       Int          @default(0)
  lowStockAt     Int?

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, sku])
  @@index([organizationId, name])
  @@index([createdAt])
}
